<div class="section-header">
  <div>
    <h2><i class="fa-solid fa-medal" style="color:var(--gold,#F5A623);"></i> Nouveau badge</h2>
  </div>
  <a href="<%= courseId ? `/instructor/courses/${courseId}` : '/instructor' %>"
     class="btn btn-ghost btn-sm">
    <i class="fa-solid fa-arrow-left"></i> Retour
  </a>
</div>

<form action="<%= courseId ? `/instructor/courses/${courseId}/badges` : '/instructor' %>"
      method="POST" enctype="multipart/form-data" class="form card" style="max-width:560px;">

  <div class="form-group">
    <label>Nom du badge <span class="req">*</span></label>
    <input type="text" name="name" required placeholder="ex: Maître Flutter">
  </div>

  <div class="form-group">
    <label>Description</label>
    <textarea name="description" rows="3" class="form-textarea"
      placeholder="Ce badge est décerné à l'étudiant qui..."></textarea>
  </div>

  <div class="form-row">
    <div class="form-group">
      <label>Condition de déclenchement</label>
      <select name="triggerCondition">
        <option value="course_complete">Cours complété</option>
        <option value="module_complete">Module complété</option>
        <option value="exercise_passed">Exercice réussi</option>
        <option value="manual">Attribution manuelle</option>
      </select>
    </div>
    <div class="form-group">
      <label>XP offert</label>
      <input type="number" name="xpValue" value="50" min="0">
    </div>
  </div>

  <div class="form-group">
    <label>Icône du badge (image)</label>
    <input type="file" name="image" accept="image/*">
    <p class="form-hint">Format PNG transparent recommandé, 256×256 px min.</p>
  </div>

  <div class="form-actions">
    <a href="<%= courseId ? `/instructor/courses/${courseId}` : '/instructor' %>"
       class="btn btn-ghost">Annuler</a>
    <button type="submit" class="btn btn-primary">
      <i class="fa-solid fa-plus"></i> Créer le badge
    </button>
  </div>
</form>
