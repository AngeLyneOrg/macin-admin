  <div class="footer-inner">
    <div>
      <a href="/" class="footer-brand">
        <img src="/img/logo.png" alt="MACIN" onerror="this.style.display='none'">
        MACIN
      </a>
      <p class="footer-desc">La plateforme d'e-formation intelligente conçue pour les apprenants africains. Propulsée par l'IA, disponible hors-ligne.</p>
      <div class="footer-socials">
        <a href="#" aria-label="Facebook"><i class="fa-brands fa-facebook-f"></i></a>
        <a href="#" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
        <a href="#" aria-label="LinkedIn"><i class="fa-brands fa-linkedin-in"></i></a>
        <a href="#" aria-label="YouTube"><i class="fa-brands fa-youtube"></i></a>
      </div>
    </div>

    <div class="footer-col">
      <h4>Navigation</h4>
      <a href="#accueil">Accueil</a>
      <a href="#maci">MACI IA</a>
      <a href="#fonctionnalites">Fonctionnalités</a>
      <a href="#telechargement">Télécharger</a>
    </div>

    <div class="footer-col">
      <h4>Légal</h4>
      <a href="#">Politique de confidentialité</a>
      <a href="#">Conditions d'utilisation</a>
      <a href="/login">Espace admin</a>
    </div>
  </div>

  <div class="footer-bottom">
    <span>&copy; <%= new Date().getFullYear() %> MACIN — CamiaEDU. Tous droits réservés.</span>
    <div style="display:flex;gap:20px;">
      <a href="#">Confidentialité</a>
      <a href="#">Conditions</a>
    </div>
  </div>
</footer>

<script>
// Nav scroll effect
const nav = document.getElementById('mainNav');
window.addEventListener('scroll', function() {
  nav.classList.toggle('scrolled', window.scrollY > 20);
});
</script>
</body>
</html>
