</section>

<!-- ── STATS STRIP ─────────────────────────────────────── -->
<div class="stats-strip">
  <div class="stats-strip-inner">
    <div>
      <div class="stat-num">500<span>+</span></div>
      <div class="stat-lbl">Apprenants actifs</div>
    </div>
    <div>
      <div class="stat-num">30<span>+</span></div>
      <div class="stat-lbl">Cours certifiants</div>
    </div>
    <div>
      <div class="stat-num">100<span>%</span></div>
      <div class="stat-lbl">Disponible hors-ligne</div>
    </div>
    <div>
      <div class="stat-num">4.9<span>★</span></div>
      <div class="stat-lbl">Note moyenne</div>
    </div>
  </div>
</div>

<!-- ── MACI ─────────────────────────────────────── -->
<section class="maci-section" id="maci">
  <div class="maci-inner section-inner">
    <div class="maci-visual-wrap">
      <div class="maci-orb"></div>
      <div class="maci-img-wrap">
        <img src="/img/maci.png" alt="MACI" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
        <span class="maci-fallback" style="display:none;">🤖</span>
      </div>
      <div class="maci-badge-chip">
        <span class="chip-dot"></span> Assistant IA actif
      </div>
    </div>

    <div>
      <span class="section-eyebrow">Intelligence Artificielle intégrée</span>
      <h2 class="section-title">Rencontrez MACI,<br>votre coach personnel</h2>
      <p class="section-body">
        MACI est un modèle IA entraîné spécifiquement pour MACIN. Il analyse votre progression,
        répond à vos questions de cours, et adapte les exercices à votre niveau — en temps réel,
        <strong>même sans internet</strong>.
      </p>

      <div class="maci-chips">
        <span class="maci-chip">🧠 100% hors-ligne</span>
        <span class="maci-chip">💬 Réponses instantanées</span>
        <span class="maci-chip">📈 Suivi personnalisé</span>
        <span class="maci-chip">🎯 Adapté à votre niveau</span>
        <span class="maci-chip">🔒 Données privées</span>
      </div>

      <a href="#telechargement" class="btn-hero-primary">
        <i class="fa-brands fa-google-play"></i> Essayer MACIN
      </a>
    </div>
  </div>
</section>

<!-- ── FEATURES ─────────────────────────────────────── -->
<section class="features-section" id="fonctionnalites">
  <div class="feat-header section-inner">
    <span class="section-eyebrow">Ce que MACIN vous offre</span>
    <h2 class="section-title">Une expérience d'apprentissage<br>complète et intelligente</h2>
    <p class="section-body">Conçu pour les apprenants africains, optimisé pour les contraintes réseau, pensé pour la progression réelle.</p>
  </div>

  <div class="feat-grid">
    <div class="feat-card">
      <div class="feat-icon"><i class="fa-solid fa-robot"></i></div>
      <h3>MACI — Coach IA</h3>
      <p>Intelligence artificielle locale qui répond à vos questions 24h/24, même sans connexion. Entraîné sur les contenus MACIN.</p>
    </div>
    <div class="feat-card">
      <div class="feat-icon"><i class="fa-solid fa-graduation-cap"></i></div>
      <h3>Cours certifiants</h3>
      <p>Obtenez des certifications reconnues à l'issue de chaque formation complétée. Valorisez vos compétences.</p>
    </div>
    <div class="feat-card">
      <div class="feat-icon"><i class="fa-solid fa-wifi"></i></div>
      <h3>Mode hors-ligne</h3>
      <p>Téléchargez vos cours et continuez d'apprendre partout, même en zone à faible connectivité.</p>
    </div>
    <div class="feat-card">
      <div class="feat-icon"><i class="fa-solid fa-bolt"></i></div>
      <h3>Exercices interactifs</h3>
      <p>Quiz, défis de code, projets guidés. Chaque leçon s'accompagne d'exercices pratiques pour ancrer les savoirs.</p>
    </div>
    <div class="feat-card">
      <div class="feat-icon"><i class="fa-solid fa-medal"></i></div>
      <h3>Badges & Récompenses</h3>
      <p>Débloquez des badges à chaque étape de votre parcours. Partagez vos accomplissements et restez motivé.</p>
    </div>
    <div class="feat-card">
      <div class="feat-icon"><i class="fa-solid fa-chart-line"></i></div>
      <h3>Suivi de progression</h3>
      <p>Visualisez votre avancement cours par cours. Identifiez vos lacunes et concentrez vos efforts au bon endroit.</p>
    </div>
  </div>
</section>

<!-- ── DOWNLOAD CTA ─────────────────────────────────────── -->
<section class="download-section" id="telechargement">
  <div class="dl-inner">
    <span class="section-eyebrow" style="color:var(--accent)">Disponible maintenant</span>
    <h2 class="section-title">Commencez votre première formation <em style="background:linear-gradient(135deg,var(--accent),#4DF0CC);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;font-style:normal">gratuitement</em></h2>
    <p class="section-body">Téléchargez l'application MACIN sur Android et accédez à des dizaines de formations, à votre rythme.</p>

    <div class="dl-actions">
      <a href="<%= apkUrl || '#' %>" class="dl-btn<%= apkUrl ? '' : '' %>">
        <span class="dl-btn-icon">🤖</span>
        <div>
          <div style="font-size:.7rem;font-weight:400;opacity:.6">Télécharger sur</div>
          Android APK
        </div>
      </a>
      <span class="dl-coming">
        <span class="dl-btn-icon"></span>
        <div>
          <div style="font-size:.7rem;font-weight:400">Bientôt sur</div>
          App Store
        </div>
      </span>
    </div>
  </div>
</section>

<!-- ── FOOTER ─────────────────────────────────────── -->
