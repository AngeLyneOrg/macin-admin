<script>
// Nav scroll
const mainNav = document.getElementById('mainNav');
window.addEventListener('scroll', () => mainNav.classList.toggle('scrolled', window.scrollY > 20));

// Hamburger mobile landing
const navHam    = document.getElementById('navHam');
const navMobile = document.getElementById('navMobile');

navHam.addEventListener('click', () => {
  const isOpen = navMobile.classList.toggle('open');
  navHam.classList.toggle('open', isOpen);
  navHam.setAttribute('aria-expanded', isOpen);
});

// Fermer au clic sur un lien
navMobile.querySelectorAll('a').forEach(a => {
  a.addEventListener('click', () => {
    navMobile.classList.remove('open');
    navHam.classList.remove('open');
    navHam.setAttribute('aria-expanded', 'false');
  });
});

// ESC
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    navMobile.classList.remove('open');
    navHam.classList.remove('open');
    navHam.setAttribute('aria-expanded', 'false');
  }
});
</script>
