<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MACIN — L'e-formation intelligente pour l'Afrique</title>
  <meta name="description" content="MACIN — Coach IA, cours certifiants, badges. Disponible sur Android.">
  <link rel="icon" href="/img/favicon-32.png" type="image/png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; }
:root {
  --ink:       #0A0E1A;
  --ink-2:     #2B3150;
  --muted:     #6B728E;
  --surface:   #F7F8FC;
  --white:     #FFFFFF;
  --primary:   #2E5BFF;
  --primary-d: #1A3FD8;
  --accent:    #00D4AA;
  --gold:      #F5A623;
  --font-d:    'Sora', sans-serif;
  --font-b:    'Inter', sans-serif;
  --r:         16px;
  --shadow:    0 4px 24px rgba(0,0,0,.07);
}
body { font-family:var(--font-b); color:var(--ink); background:var(--white); overflow-x:hidden; line-height:1.65; }

/* ── NAV ─────────────────────────────────────────────── */
.nav {
  position:fixed; top:0; left:0; right:0; z-index:200;
  display:flex; align-items:center; justify-content:space-between;
  padding:0 48px; height:68px;
  background:rgba(255,255,255,.9); backdrop-filter:blur(16px);
  border-bottom:1px solid rgba(0,0,0,.06); transition:box-shadow .2s;
}
.nav.scrolled { box-shadow:0 2px 16px rgba(0,0,0,.08); }
.nav-logo {
  display:flex; align-items:center; gap:10px;
  font-family:var(--font-d); font-weight:800; font-size:1.3rem;
  color:var(--ink); text-decoration:none; flex-shrink:0;
}
.nav-logo img { height:32px; }
.nav-logo-dot { color:var(--primary); }
.nav-links {
  display:flex; align-items:center; gap:36px; list-style:none;
}
.nav-links a {
  font-size:.9rem; font-weight:500; color:var(--ink-2);
  text-decoration:none; transition:color .15s;
}
.nav-links a:hover { color:var(--primary); }
.nav-actions { display:flex; align-items:center; gap:10px; }
.btn-nav {
  padding:9px 20px; border-radius:50px; font-size:.85rem; font-weight:700;
  cursor:pointer; text-decoration:none; border:none; transition:all .2s;
  display:inline-flex; align-items:center; gap:7px;
}
.btn-nav-ghost    { background:transparent; color:var(--ink-2); border:1.5px solid rgba(0,0,0,.12); }
.btn-nav-ghost:hover { border-color:var(--primary); color:var(--primary); }
.btn-nav-outline  { background:transparent; color:var(--primary); border:1.5px solid var(--primary); }
.btn-nav-outline:hover { background:var(--primary); color:#fff; }
.btn-nav-primary  { background:var(--primary); color:#fff; }
.btn-nav-primary:hover { background:var(--primary-d); transform:translateY(-1px); }

/* Hamburger nav */
.nav-ham {
  display:none; background:none; border:1.5px solid rgba(0,0,0,.12);
  border-radius:8px; padding:8px; cursor:pointer;
  flex-direction:column; gap:4.5px; width:38px; height:38px;
  align-items:center; justify-content:center;
}
.nav-ham-bar { display:block; width:16px; height:2px; background:var(--ink-2); border-radius:2px; transition:all .25s; }
.nav-ham.open .nav-ham-bar:nth-child(1) { transform:translateY(6.5px) rotate(45deg); }
.nav-ham.open .nav-ham-bar:nth-child(2) { opacity:0; }
.nav-ham.open .nav-ham-bar:nth-child(3) { transform:translateY(-6.5px) rotate(-45deg); }

/* Mobile menu drawer */
.nav-mobile {
  position:fixed; top:68px; left:0; right:0; z-index:190;
  background:var(--white); border-bottom:1px solid rgba(0,0,0,.08);
  padding:20px 28px; display:none; flex-direction:column; gap:6px;
  box-shadow:0 8px 32px rgba(0,0,0,.1);
}
.nav-mobile.open { display:flex; }
.nav-mobile a {
  display:flex; align-items:center; gap:10px;
  padding:12px 14px; border-radius:10px;
  font-size:.9rem; font-weight:600; color:var(--ink-2);
  text-decoration:none; transition:background .15s;
}
.nav-mobile a:hover { background:var(--surface); color:var(--primary); }
.nav-mobile .nm-divider { height:1px; background:rgba(0,0,0,.07); margin:8px 0; }
.nav-mobile .nm-cta { background:var(--primary); color:#fff; justify-content:center; }
.nav-mobile .nm-cta:hover { background:var(--primary-d); }
.nav-mobile .nm-outline { border:1.5px solid var(--primary); color:var(--primary); justify-content:center; }
.nav-mobile .nm-outline:hover { background:var(--primary); color:#fff; }

/* ── HERO ─────────────────────────────────────────────── */
.hero {
  min-height:100vh; display:flex; align-items:center;
  padding:110px 48px 80px;
  background:linear-gradient(135deg,#F0F4FF 0%,#FAFAFF 60%,#E8FFF8 100%);
  position:relative; overflow:hidden;
}
.hero::before {
  content:''; position:absolute; top:-200px; right:-100px;
  width:700px; height:700px;
  background:radial-gradient(circle,rgba(46,91,255,.1) 0%,transparent 65%);
  pointer-events:none;
}
.hero::after {
  content:''; position:absolute; bottom:-150px; left:-100px;
  width:500px; height:500px;
  background:radial-gradient(circle,rgba(0,212,170,.12) 0%,transparent 65%);
  pointer-events:none;
}
.hero-inner {
  max-width:1280px; margin:0 auto; width:100%;
  display:grid; grid-template-columns:1fr 1fr; gap:60px; align-items:center;
  position:relative; z-index:1;
}
.hero-eyebrow {
  display:inline-flex; align-items:center; gap:8px;
  background:rgba(46,91,255,.08); border:1px solid rgba(46,91,255,.2);
  border-radius:50px; padding:6px 16px;
  font-size:.8rem; font-weight:700; color:var(--primary); margin-bottom:24px;
}
.eye-dot { width:6px; height:6px; background:var(--accent); border-radius:50%; animation:pulse 2s infinite; }
@keyframes pulse { 0%,100%{opacity:1}50%{opacity:.4} }
.hero-title {
  font-family:var(--font-d); font-size:clamp(2.4rem,5vw,3.8rem);
  font-weight:800; line-height:1.12; color:var(--ink);
  margin-bottom:22px; letter-spacing:-1px;
}
.hero-title em {
  font-style:normal;
  background:linear-gradient(135deg,var(--primary) 0%,var(--accent) 100%);
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
}
.hero-body { font-size:1.05rem; color:var(--muted); max-width:520px; margin-bottom:36px; line-height:1.8; }
.hero-actions { display:flex; align-items:center; gap:14px; flex-wrap:wrap; margin-bottom:32px; }
.btn-hero-primary {
  display:inline-flex; align-items:center; gap:10px;
  background:var(--primary); color:#fff;
  padding:15px 30px; border-radius:50px;
  font-family:var(--font-d); font-weight:700; font-size:1rem;
  text-decoration:none; transition:all .25s;
  box-shadow:0 8px 24px rgba(46,91,255,.3);
}
.btn-hero-primary:hover { background:var(--primary-d); transform:translateY(-2px); }
.btn-hero-secondary {
  display:inline-flex; align-items:center; gap:10px;
  background:#fff; color:var(--primary);
  padding:15px 30px; border-radius:50px;
  font-family:var(--font-d); font-weight:700; font-size:1rem;
  text-decoration:none; transition:all .25s;
  border:1.5px solid var(--primary);
  box-shadow:var(--shadow);
}
.btn-hero-secondary:hover { background:var(--primary); color:#fff; transform:translateY(-2px); }
.btn-hero-ghost {
  display:inline-flex; align-items:center; gap:8px;
  color:var(--ink-2); font-weight:600; font-size:.95rem;
  text-decoration:none; transition:color .15s;
}
.btn-hero-ghost:hover { color:var(--primary); }
.hero-trust { display:flex; align-items:center; gap:16px; }
.hero-stars { color:var(--gold); font-size:.85rem; }
.hero-trust-text { font-size:.8rem; color:var(--muted); font-weight:500; }

/* Hero visual */
.hero-visual { position:relative; display:flex; justify-content:center; }
.phone-shell { position:relative; width:280px; filter:drop-shadow(0 40px 80px rgba(46,91,255,.2)); }
.phone-shell img { width:100%; display:block; border-radius:36px; }
.hero-glow {
  position:absolute; top:50%; left:50%; transform:translate(-50%,-50%);
  width:400px; height:400px; border-radius:50%;
  border:1px solid rgba(46,91,255,.1); z-index:-1;
}
.hero-glow::before {
  content:''; position:absolute; top:30px; left:30px; right:30px; bottom:30px;
  border-radius:50%; border:1px solid rgba(46,91,255,.07);
}
.float-card {
  position:absolute; background:#fff; border-radius:var(--r);
  padding:11px 15px; box-shadow:var(--shadow);
  display:flex; align-items:center; gap:10px;
  font-size:.82rem; font-weight:600; white-space:nowrap;
  animation:floatY 4s ease-in-out infinite;
}
.float-card.fc-left  { left:-60px; top:30%; animation-delay:0s; }
.float-card.fc-right { right:-50px; top:55%; animation-delay:1.5s; }
.float-card.fc-top   { right:-40px; top:8%; animation-delay:.8s; }
@keyframes floatY { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
.fc-icon {
  width:30px; height:30px; border-radius:8px;
  display:flex; align-items:center; justify-content:center; font-size:.9rem; flex-shrink:0;
}
.fc-blue   { background:#E8EEFF; color:var(--primary); }
.fc-green  { background:#E0FFF7; color:#00A882; }
.fc-gold   { background:#FFF8E0; color:var(--gold); }
.fc-label  { color:var(--muted); font-size:.7rem; font-weight:400; }

/* ── STATS STRIP ─────────────────────────────────────────── */
.stats-strip { background:var(--ink); padding:48px; }
.stats-strip-inner { max-width:900px; margin:0 auto; display:grid; grid-template-columns:repeat(4,1fr); gap:40px; text-align:center; }
.stat-num { font-family:var(--font-d); font-size:2.4rem; font-weight:800; color:#fff; line-height:1; }
.stat-num span { color:var(--accent); }
.stat-lbl { font-size:.82rem; color:rgba(255,255,255,.45); margin-top:6px; }

/* ── SECTIONS ─────────────────────────────────────────────── */
section { padding:100px 48px; }
.section-inner { max-width:1280px; margin:0 auto; }
.section-eyebrow { display:inline-block; font-size:.78rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:var(--primary); margin-bottom:14px; }
.section-title { font-family:var(--font-d); font-size:clamp(1.8rem,4vw,2.8rem); font-weight:800; line-height:1.15; color:var(--ink); letter-spacing:-.5px; }
.section-body { font-size:1.05rem; color:var(--muted); max-width:560px; line-height:1.8; margin-top:14px; }

/* ── MACI ─────────────────────────────────────────────── */
.maci-section { background:var(--surface); }
.maci-inner { max-width:1280px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:center; }
.maci-visual-wrap { position:relative; display:flex; justify-content:center; }
.maci-orb {
  width:320px; height:320px; border-radius:50%;
  background:conic-gradient(from 200deg,var(--accent) 0%,var(--primary) 50%,var(--accent) 100%);
  opacity:.1; position:absolute; top:50%; left:50%; transform:translate(-50%,-50%);
  animation:spin 20s linear infinite;
}
@keyframes spin { from{transform:translate(-50%,-50%) rotate(0deg)} to{transform:translate(-50%,-50%) rotate(360deg)} }
.maci-img-wrap {
  position:relative; z-index:1; width:260px; height:260px; border-radius:50%;
  background:linear-gradient(135deg,var(--primary) 0%,#7C3AED 100%);
  display:flex; align-items:center; justify-content:center;
  box-shadow:0 24px 64px rgba(46,91,255,.3);
}
.maci-img-wrap img { width:180px; border-radius:50%; object-fit:cover; }
.maci-fallback { font-size:5rem; }
.maci-badge-chip {
  position:absolute; bottom:10px; right:-20px;
  background:#fff; border-radius:50px; padding:10px 18px;
  box-shadow:var(--shadow); font-size:.82rem; font-weight:700;
  display:flex; align-items:center; gap:8px; color:var(--primary); z-index:2;
}
.chip-dot { width:7px; height:7px; background:var(--accent); border-radius:50%; animation:pulse 2s infinite; }
.maci-chips { display:flex; flex-wrap:wrap; gap:10px; margin:24px 0 32px; }
.maci-chip {
  background:#fff; border:1.5px solid rgba(46,91,255,.15);
  border-radius:50px; padding:7px 16px;
  font-size:.82rem; font-weight:600; color:var(--ink-2);
}

/* ── FEATURES ─────────────────────────────────────────────── */
.features-section { background:var(--white); }
.feat-header { text-align:center; margin-bottom:60px; }
.feat-header .section-body { margin:14px auto 0; text-align:center; }
.feat-grid { max-width:1280px; margin:0 auto; display:grid; grid-template-columns:repeat(3,1fr); gap:24px; }
.feat-card {
  background:var(--white); border:1.5px solid rgba(0,0,0,.07);
  border-radius:20px; padding:32px 28px; transition:all .25s;
  position:relative; overflow:hidden;
}
.feat-card::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; background:linear-gradient(90deg,var(--primary),var(--accent)); opacity:0; transition:opacity .25s; }
.feat-card:hover { border-color:rgba(46,91,255,.2); transform:translateY(-4px); box-shadow:0 16px 48px rgba(46,91,255,.1); }
.feat-card:hover::before { opacity:1; }
.feat-icon { width:48px; height:48px; border-radius:12px; background:#EFF3FF; color:var(--primary); display:flex; align-items:center; justify-content:center; font-size:1.2rem; margin-bottom:18px; }
.feat-card h3 { font-family:var(--font-d); font-size:1rem; font-weight:700; margin-bottom:10px; }
.feat-card p  { font-size:.875rem; color:var(--muted); line-height:1.7; }

/* ── FORMATEUR CTA ─────────────────────────────────────────── */
.instructor-cta {
  background:linear-gradient(135deg,#1A1F4E 0%,#2E5BFF 100%);
  padding:80px 48px;
}
.instructor-cta-inner {
  max-width:900px; margin:0 auto;
  display:grid; grid-template-columns:1fr auto; gap:48px; align-items:center;
}
.instructor-cta-title { font-family:var(--font-d); font-size:clamp(1.6rem,3vw,2.4rem); font-weight:800; color:#fff; margin-bottom:12px; }
.instructor-cta-body  { font-size:1rem; color:rgba(255,255,255,.65); line-height:1.8; margin-bottom:28px; }
.instructor-cta-perks { display:flex; flex-direction:column; gap:10px; }
.perk { display:flex; align-items:center; gap:10px; font-size:.875rem; color:rgba(255,255,255,.8); }
.perk i { color:var(--accent); }
.btn-instructor {
  display:inline-flex; align-items:center; gap:10px;
  background:#fff; color:var(--primary);
  padding:16px 32px; border-radius:50px;
  font-family:var(--font-d); font-weight:800; font-size:1rem;
  text-decoration:none; transition:all .25s;
  box-shadow:0 8px 24px rgba(0,0,0,.25); white-space:nowrap;
}
.btn-instructor:hover { transform:translateY(-3px); box-shadow:0 14px 36px rgba(0,0,0,.3); }

/* ── DOWNLOAD ─────────────────────────────────────────────── */
.download-section {
  background:linear-gradient(135deg,#0A0E1A 0%,#1A235E 100%);
  padding:100px 48px; text-align:center; position:relative; overflow:hidden;
}
.download-section::before {
  content:''; position:absolute; top:-200px; right:-150px; width:600px; height:600px; border-radius:50%;
  background:radial-gradient(circle,rgba(46,91,255,.3) 0%,transparent 65%);
}
.dl-inner { position:relative; z-index:1; max-width:700px; margin:0 auto; }
.dl-inner .section-title { color:#fff; }
.dl-inner .section-body  { color:rgba(255,255,255,.55); margin:16px auto 48px; text-align:center; }
.dl-actions { display:flex; justify-content:center; gap:16px; flex-wrap:wrap; }
.dl-btn {
  display:inline-flex; align-items:center; gap:14px;
  background:#fff; color:var(--ink); padding:16px 32px; border-radius:50px;
  font-family:var(--font-d); font-weight:700; font-size:.95rem;
  text-decoration:none; transition:all .25s; box-shadow:0 8px 32px rgba(0,0,0,.3);
}
.dl-btn:hover { transform:translateY(-3px); box-shadow:0 14px 40px rgba(0,0,0,.4); }
.dl-coming {
  display:inline-flex; align-items:center; gap:14px;
  background:rgba(255,255,255,.08); color:rgba(255,255,255,.4);
  padding:16px 32px; border-radius:50px;
  font-family:var(--font-d); font-weight:700; font-size:.95rem;
  text-decoration:none; border:1.5px solid rgba(255,255,255,.1); cursor:not-allowed;
}
.dl-btn-icon { font-size:1.4rem; }

/* ── FOOTER ─────────────────────────────────────────────── */
.footer { background:var(--ink); border-top:1px solid rgba(255,255,255,.06); padding:64px 48px 40px; }
.footer-inner { max-width:1280px; margin:0 auto; display:grid; grid-template-columns:2fr 1fr 1fr; gap:60px; }
.footer-brand { display:flex; align-items:center; gap:10px; font-family:var(--font-d); font-weight:800; font-size:1.2rem; color:#fff; text-decoration:none; margin-bottom:14px; }
.footer-brand img { height:28px; }
.footer-desc { font-size:.875rem; color:rgba(255,255,255,.38); line-height:1.8; }
.footer-socials { display:flex; gap:12px; margin-top:22px; }
.footer-socials a {
  width:36px; height:36px; border-radius:50%; background:rgba(255,255,255,.06);
  color:rgba(255,255,255,.5); display:flex; align-items:center; justify-content:center;
  font-size:.82rem; text-decoration:none; transition:all .2s;
}
.footer-socials a:hover { background:var(--primary); color:#fff; }
.footer-col h4 { font-family:var(--font-d); font-size:.82rem; font-weight:700; color:#fff; margin-bottom:16px; letter-spacing:.05em; text-transform:uppercase; }
.footer-col a  { display:block; font-size:.85rem; color:rgba(255,255,255,.42); text-decoration:none; margin-bottom:11px; transition:color .15s; }
.footer-col a:hover { color:rgba(255,255,255,.85); }
.footer-bottom {
  max-width:1280px; margin:48px auto 0; padding-top:24px;
  border-top:1px solid rgba(255,255,255,.06);
  display:flex; align-items:center; justify-content:space-between;
  font-size:.78rem; color:rgba(255,255,255,.28);
}
.footer-bottom a { color:rgba(255,255,255,.28); text-decoration:none; }
.footer-bottom a:hover { color:rgba(255,255,255,.7); }
.footer-bottom-links { display:flex; gap:20px; }

/* ── RESPONSIVE ─────────────────────────────────────────────── */
@media (max-width:1024px) {
  .feat-grid { grid-template-columns:repeat(2,1fr); }
  .hero-inner, .maci-inner { grid-template-columns:1fr; text-align:center; }
  .hero-visual { display:none; }
  .maci-visual-wrap { margin-bottom:40px; }
  .instructor-cta-inner { grid-template-columns:1fr; text-align:center; }
  .btn-instructor { justify-content:center; }
  .footer-inner { grid-template-columns:1fr 1fr; }
  .stats-strip-inner { grid-template-columns:repeat(2,1fr); }
}
@media (max-width:768px) {
  .nav { padding:0 20px; }
  .nav-links, .btn-nav-outline, .btn-nav-ghost, .btn-nav-primary { display:none; }
  .nav-ham { display:flex; }
  section, .hero { padding-left:24px; padding-right:24px; }
  .feat-grid { grid-template-columns:1fr; }
  .footer-inner { grid-template-columns:1fr; }
  .stats-strip { padding:40px 24px; }
  .stats-strip-inner { grid-template-columns:repeat(2,1fr); gap:24px; }
  .hero-actions { justify-content:center; }
  .maci-chips { justify-content:center; }
  .instructor-cta { padding:60px 24px; }
  .download-section { padding:72px 24px; }
  .footer { padding:48px 24px 32px; }
  .footer-bottom { flex-direction:column; gap:12px; text-align:center; }
}
</style>
</head>
<body>

<!-- ── NAV ─────────────────────────────────────────────── -->
<nav class="nav" id="mainNav">
  <a href="/" class="nav-logo">
    <img src="/img/logo.png" alt="MACIN" onerror="this.style.display='none'">
    MACIN<span class="nav-logo-dot">.</span>
  </a>

  <ul class="nav-links">
    <li><a href="#maci">MACI IA</a></li>
    <li><a href="#fonctionnalites">Fonctionnalités</a></li>
    <li><a href="#formateurs">Formateurs</a></li>
    <li><a href="#telechargement">Télécharger</a></li>
  </ul>

  <div class="nav-actions">
    <a href="/devenir-formateur" class="btn-nav btn-nav-outline">
      <i class="fa-solid fa-chalkboard-user"></i> Devenir formateur
    </a>
    <a href="/login" class="btn-nav btn-nav-primary">
      <i class="fa-solid fa-right-to-bracket"></i> Connexion
    </a>
    <button class="nav-ham" id="navHam" aria-label="Menu" aria-expanded="false">
      <span class="nav-ham-bar"></span>
      <span class="nav-ham-bar"></span>
      <span class="nav-ham-bar"></span>
    </button>
  </div>
</nav>

<!-- Menu mobile -->
<div class="nav-mobile" id="navMobile" role="navigation" aria-label="Menu mobile">
  <a href="#maci"><i class="fa-solid fa-robot"></i> MACI IA</a>
  <a href="#fonctionnalites"><i class="fa-solid fa-star"></i> Fonctionnalités</a>
  <a href="#formateurs"><i class="fa-solid fa-chalkboard-user"></i> Pour les formateurs</a>
  <a href="#telechargement"><i class="fa-brands fa-google-play"></i> Télécharger</a>
