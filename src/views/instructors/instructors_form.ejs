<div class="section-header">
  <h2><%= instructor ? 'Modifier le formateur' : 'Nouveau formateur' %></h2>
  <a href="/dashboard/instructors" class="btn btn-ghost btn-sm">← Retour</a>
</div>

<form action="<%= instructor ? `/dashboard/instructors/${instructor.id}` : '/instructors' %>" method="POST" enctype="multipart/form-data" class="form card">
  <% if (instructor) { %>
    <p class="form-hint">UID Firestore : <code><%= instructor.id %></code></p>
  <% } else { %>
    <div class="form-group">
      <label for="uid">UID Firebase Auth (optionnel)</label>
      <input type="text" name="uid" id="uid" placeholder="Laisse vide pour générer un ID automatiquement">
      <p class="form-hint">Si ce formateur a déjà un compte Firebase Auth (inscription via l'app), colle son UID ici pour lier les deux. Sinon laisse vide — utile pour un formateur "vitrine" sans compte actif.</p>
    </div>
  <% } %>

  <div class="form-group">
    <label for="displayName">Nom complet</label>
    <input type="text" name="displayName" id="displayName" required value="<%= instructor ? instructor.displayName : '' %>">
  </div>

  <div class="form-group">
    <label for="email">Email</label>
    <input type="email" name="email" id="email" required value="<%= instructor ? instructor.email : '' %>">
  </div>

  <div class="form-group">
    <label for="bio">Bio</label>
    <textarea name="bio" id="bio" rows="3"><%= instructor ? instructor.bio : '' %></textarea>
  </div>

  <div class="form-group">
    <label for="photo">Photo de profil</label>
    <input type="file" name="photo" id="photo" accept="image/*">
    <% if (instructor && instructor.photoUrl) { %>
      <img src="<%= instructor.photoUrl %>" alt="Photo actuelle" class="thumb-preview thumb-round">
    <% } %>
  </div>

  <button type="submit" class="btn btn-primary"><%= instructor ? 'Enregistrer' : 'Créer le formateur' %></button>
</form>
