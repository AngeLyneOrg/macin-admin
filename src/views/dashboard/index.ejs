<div class="stats-grid">
  <%- include('../partials/stat-card', { icon: 'fa-solid fa-book-open', value: stats.totalCourses, label: 'Formations' }) %>
  <%- include('../partials/stat-card', { icon: 'fa-solid fa-circle-check', value: stats.publishedCount, label: 'Publiées' }) %>
  <%- include('../partials/stat-card', { icon: 'fa-solid fa-pen', value: stats.draftCount, label: 'Brouillons' }) %>
  <%- include('../partials/stat-card', { icon: 'fa-solid fa-film', value: stats.totalLessons, label: 'Leçons' }) %>
  <%- include('../partials/stat-card', { icon: 'fa-solid fa-chalkboard-user', value: stats.totalInstructors, label: 'Formateurs' }) %>
  <%- include('../partials/stat-card', { icon: 'fa-solid fa-medal', value: stats.totalBadges, label: 'Badges' }) %>
</div>

<div class="section-header">
  <h2>Formations récentes</h2>
  <a href="/courses/new" class="btn btn-primary btn-sm"><i class="fa-solid fa-plus"></i> Nouvelle formation</a>
</div>

<% if (recentCourses.length === 0) { %>
  <%- include('../partials/empty-state', {
    icon: 'fa-solid fa-book-open',
    title: 'Aucune formation pour le moment',
    subtitle: 'Crée ta première formation pour commencer.',
    ctaHref: '/courses/new',
    ctaLabel: 'Créer une formation'
  }) %>
<% } else { %>
  <div class="course-grid">
    <% recentCourses.forEach(function(course) { %>
      <%- include('../partials/course-card', { course }) %>
    <% }) %>
  </div>
<% } %>
