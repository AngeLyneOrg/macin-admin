<div class="section-header">
  <h2><%= course ? 'Modifier la formation' : 'Nouvelle formation' %></h2>
  <a href="/dashboard/courses" class="btn btn-ghost btn-sm">← Retour</a>
</div>

<form action="<%= course ? `/dashboard/courses/${course.id}` : '/dashboard/courses' %>" method="POST" enctype="multipart/form-data" class="form card">
  <div class="form-group">
    <label for="title">Titre de la formation</label>
    <input type="text" name="title" id="title" required value="<%= course ? course.title : '' %>">
  </div>

  <div class="form-group">
    <label for="description">Description</label>
    <textarea name="description" id="description" rows="4"><%= course ? course.description : '' %></textarea>
  </div>

  <div class="form-row">
    <div class="form-group">
      <label for="level">Niveau</label>
      <select name="level" id="level">
        <% ['beginner', 'intermediate', 'advanced'].forEach(function(lvl) { %>
          <option value="<%= lvl %>" <%= course && course.level === lvl ? 'selected' : '' %>>
            <%= lvl === 'beginner' ? 'Débutant' : lvl === 'intermediate' ? 'Intermédiaire' : 'Avancé' %>
          </option>
        <% }) %>
      </select>
    </div>
    <div class="form-group">
      <label for="price">Prix (0 = gratuit)</label>
      <input type="number" name="price" id="price" min="0" step="100" value="<%= course ? course.price : 0 %>">
    </div>
  </div>

  <div class="form-group">
    <label for="instructorId">Formateur</label>
    <select name="instructorId" id="instructorId">
      <option value="">— Aucun formateur assigné —</option>
      <% instructors.forEach(function(inst) { %>
        <option value="<%= inst.id %>" <%= course && course.instructorId === inst.id ? 'selected' : '' %>>
          <%= inst.displayName %>
        </option>
      <% }) %>
    </select>
    <p class="form-hint">Pas encore de formateur ? <a href="/dashboard/instructors/new">Crée-en un d'abord</a>.</p>
  </div>

  <div class="form-group">
    <label for="tags">Tags (séparés par des virgules)</label>
    <input type="text" name="tags" id="tags" placeholder="flutter, dart, firebase"
      value="<%= course && course.tags ? course.tags.join(', ') : '' %>">
  </div>

  <div class="form-group">
    <label for="thumbnail">Miniature de la formation</label>
    <input type="file" name="thumbnail" id="thumbnail" accept="image/*">
    <% if (course && course.thumbnailUrl) { %>
      <img src="<%= course.thumbnailUrl %>" alt="Miniature actuelle" class="thumb-preview">
    <% } %>
  </div>

  <div class="form-checkbox">
    <input type="checkbox" name="isPublished" id="isPublished" <%= course && course.isPublished ? 'checked' : '' %>>
    <label for="isPublished">Publier cette formation (visible dans l'application mobile)</label>
  </div>

  <button type="submit" class="btn btn-primary"><%= course ? 'Enregistrer les modifications' : 'Créer la formation' %></button>
</form>
