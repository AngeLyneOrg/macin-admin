<div class="section-header">
  <div>
    <h2><i class="fa-solid fa-book-open"></i> Mes formations</h2>
    <p class="text-muted"><%= courses.length %> formation<%= courses.length > 1 ? 's' : '' %></p>
  </div>
  <a href="/instructor/courses/new" class="btn btn-primary btn-sm">
    <i class="fa-solid fa-plus"></i> Nouvelle formation
  </a>
</div>

<% if (courses.length === 0) { %>
  <%- include('../partials/empty-state', {
    icon:     'fa-solid fa-book-open',
    title:    'Aucune formation pour le moment',
    subtitle: 'Crée ta première formation et commence à partager ton expertise.',
    ctaHref:  '/instructor/courses/new',
    ctaLabel: 'Créer une formation'
  }) %>
<% } else { %>
  <div class="course-grid">
    <% courses.forEach(function(course) { %>
      <%- include('../partials/course-card', { course }) %>
    <% }) %>
  </div>
<% } %>
