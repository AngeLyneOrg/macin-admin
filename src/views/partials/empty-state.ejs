<div class="empty-state">
  <div class="empty-icon"><i class="<%= icon || 'fa-solid fa-inbox' %>"></i></div>
  <p class="empty-title"><%= title %></p>
  <% if (typeof subtitle !== 'undefined') { %><p class="empty-subtitle"><%= subtitle %></p><% } %>
  <% if (typeof ctaHref !== 'undefined') { %>
    <a href="<%= ctaHref %>" class="btn btn-primary"><%= ctaLabel %></a>
  <% } %>
</div>
