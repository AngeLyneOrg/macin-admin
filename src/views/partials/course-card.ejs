<a href="/instructor/courses/<%= course.id %>" class="course-card">
  <div class="course-thumb" style="background-image:url('<%= course.thumbnailUrl || '/img/placeholder.png' %>')">
    <span class="course-pill <%= course.isPublished ? 'pill-published' : 'pill-draft' %>">
      <%= course.isPublished ? 'Publié' : 'Brouillon' %>
    </span>
  </div>
  <div class="course-card-body">
    <h3 class="course-card-title"><%= course.title %></h3>
    <p class="course-card-meta"><%= course.totalLessons || 0 %> leçons · <%= course.level %></p>
  </div>
</a>
