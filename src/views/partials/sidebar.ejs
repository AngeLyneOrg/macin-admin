<aside class="sidebar">
  <!-- Bouton fermer (mobile) -->
  <button class="sidebar-close" aria-label="Fermer le menu">
    <i class="fa-solid fa-xmark"></i>
  </button>

  <div class="sidebar-brand">
    <img src="/img/logo.png" alt="MACIN" class="brand-logo"
         onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
    <span class="brand-mark" style="display:none;">M</span>
    <span class="brand-name">MACIN Admin</span>
  </div>

  <!-- ── Section Formateur ── -->
  <div class="nav-section-label">Espace Formateur</div>
  <nav class="sidebar-nav">
    <a href="/dashboard" class="nav-link <%= (currentPath === '/dashboard') ? 'active' : '' %>">
      <i class="fa-solid fa-gauge nav-icon"></i> Tableau de bord
    </a>
    <a href="/dashboard/courses" class="nav-link <%= currentPath.startsWith('/dashboard/courses') ? 'active' : '' %>">
      <i class="fa-solid fa-book-open nav-icon"></i> Mes formations
    </a>
    <a href="/dashboard/instructors" class="nav-link <%= currentPath.startsWith('/dashboard/instructors') ? 'active' : '' %>">
      <i class="fa-solid fa-chalkboard-user nav-icon"></i> Formateurs
    </a>
    <a href="/dashboard/badges" class="nav-link <%= currentPath.startsWith('/dashboard/badges') ? 'active' : '' %>">
      <i class="fa-solid fa-medal nav-icon"></i> Badges
    </a>
  </nav>

  <!-- ── Section Admin ── -->
  <div class="nav-section-label nav-section-sep">Administration</div>
  <nav class="sidebar-nav">
    <a href="/admin" class="nav-link <%= currentPath === '/admin' ? 'active' : '' %>">
      <i class="fa-solid fa-shield-halved nav-icon"></i> Vue globale
    </a>
    <a href="/admin/users" class="nav-link <%= currentPath.startsWith('/admin/users') ? 'active' : '' %>">
      <i class="fa-solid fa-users nav-icon"></i> Utilisateurs
    </a>
    <a href="/admin/payments" class="nav-link <%= currentPath.startsWith('/admin/payments') ? 'active' : '' %>">
      <i class="fa-solid fa-credit-card nav-icon"></i> Paiements
    </a>
  </nav>

  <div class="sidebar-footer">
    <p>MACIN — E-Formation IA</p>
  </div>
</aside>
