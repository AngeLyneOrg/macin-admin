<aside class="sidebar">
  <!-- Bouton fermer (visible mobile seulement) -->
  <button class="sidebar-close" aria-label="Fermer le menu">
    <i class="fa-solid fa-xmark"></i>
  </button>

  <div class="sidebar-brand">
    <img src="/img/logo.png" alt="MACIN" class="brand-logo"
         onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
    <span class="brand-mark" style="display:none;">M</span>
    <span class="brand-name">MACIN Admin</span>
  </div>

  <nav class="sidebar-nav">
    <a href="/dashboard" class="nav-link <%= (currentPath === '/' || currentPath === '/dashboard') ? 'active' : '' %>">
      <i class="fa-solid fa-chart-line nav-icon"></i> Tableau de bord
    </a>
    <a href="/dashboard/courses" class="nav-link <%= currentPath.startsWith('/dashboard/courses') ? 'active' : '' %>">
      <i class="fa-solid fa-book-open nav-icon"></i> Formations
    </a>
    <a href="/dashboard/instructors" class="nav-link <%= currentPath.startsWith('/dashboard/instructors') ? 'active' : '' %>">
      <i class="fa-solid fa-chalkboard-user nav-icon"></i> Formateurs
    </a>
    <a href="/dashboard/badges" class="nav-link <%= currentPath.startsWith('/dashboard/badges') ? 'active' : '' %>">
      <i class="fa-solid fa-medal nav-icon"></i> Badges
    </a>
  </nav>

  <div class="sidebar-footer">
    <p>MACIN — E-Formation IA</p>
  </div>
</aside>
