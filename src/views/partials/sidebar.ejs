<aside class="sidebar">
  <div class="sidebar-brand">
    <img src="/img/logo.png" alt="MACIN" class="brand-logo" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
    <span class="brand-mark" style="display:none;">M</span>
    <span class="brand-name">MACIN Admin</span>
  </div>

  <nav class="sidebar-nav">
    <a href="/" class="nav-link <%= currentPath === '/' ? 'active' : '' %>">
      <i class="fa-solid fa-chart-line nav-icon"></i> Tableau de bord
    </a>
    <a href="/courses" class="nav-link <%= currentPath.startsWith('/courses') ? 'active' : '' %>">
      <i class="fa-solid fa-book-open nav-icon"></i> Formations
    </a>
    <a href="/instructors" class="nav-link <%= currentPath.startsWith('/instructors') ? 'active' : '' %>">
      <i class="fa-solid fa-chalkboard-user nav-icon"></i> Formateurs
    </a>
    <a href="/badges" class="nav-link <%= currentPath.startsWith('/badges') ? 'active' : '' %>">
      <i class="fa-solid fa-medal nav-icon"></i> Badges
    </a>
  </nav>

  <div class="sidebar-footer">
    <p>MACIN — E-Formation IA</p>
  </div>
</aside>
