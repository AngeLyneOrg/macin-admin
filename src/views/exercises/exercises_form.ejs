<div class="section-header">
  <h2><i class="fa-solid fa-clipboard-question"></i> <%= exercise ? 'Modifier l\'exercice' : 'Nouvel exercice' %></h2>
  <a href="/dashboard/courses/<%= courseId %>" class="btn btn-ghost btn-sm">← Retour à <%= courseTitle %></a>
</div>

<form action="<%= exercise ? `/dashboard/courses/${courseId}/modules/${moduleId}/exercises/${exercise.id}` : `/dashboard/courses/${courseId}/modules/${moduleId}/exercises` %>"
      method="POST" class="form card" style="max-width: 820px;" id="exercise-form">

  <div class="form-row">
    <div class="form-group">
      <label>Titre</label>
      <input type="text" name="title" required value="<%= exercise ? exercise.title : '' %>">
    </div>
    <div class="form-group">
      <label>Type</label>
      <select name="type" id="exercise-type">
        <% ['quiz','code_challenge','exam','certification_test'].forEach(function(t) { %>
          <option value="<%= t %>" <%= exercise && exercise.type === t ? 'selected' : '' %>><%= t %></option>
        <% }) %>
      </select>
      <p class="form-hint">quiz = QCM simple · exam = examen noté · certification_test = test final de certification · code_challenge = exercice de code</p>
    </div>
  </div>

  <div class="form-group">
    <label>Description / Consigne</label>
    <textarea name="description" rows="3"><%= exercise ? exercise.description : '' %></textarea>
  </div>

  <div class="form-row">
    <div class="form-group">
      <label>Ordre</label>
      <input type="number" name="order" value="<%= exercise ? exercise.order : 1 %>">
    </div>
    <div class="form-group">
      <label>Seuil de réussite (%)</label>
      <input type="number" name="passingScore" value="<%= exercise ? exercise.passingScore : 70 %>">
    </div>
    <div class="form-group">
      <label>XP récompensé</label>
      <input type="number" name="xpReward" value="<%= exercise ? exercise.xpReward : 25 %>">
    </div>
    <div class="form-group">
      <label>Limite de temps (min, optionnel)</label>
      <input type="number" name="timeLimitMin" value="<%= exercise && exercise.timeLimitMin ? exercise.timeLimitMin : '' %>">
    </div>
  </div>

  <!-- Champs spécifiques code_challenge -->
  <div id="code-fields" class="card" style="background:#fafbfd;">
    <h4 style="margin-top:0;"><i class="fa-solid fa-code"></i> Champs pour exercice de code</h4>
    <div class="form-group">
      <label>Langage</label>
      <select name="codeLanguage">
        <option value="dart" <%= exercise && exercise.codeLanguage === 'dart' ? 'selected' : '' %>>Dart</option>
        <option value="python" <%= exercise && exercise.codeLanguage === 'python' ? 'selected' : '' %>>Python</option>
        <option value="javascript" <%= exercise && exercise.codeLanguage === 'javascript' ? 'selected' : '' %>>JavaScript</option>
      </select>
    </div>
    <div class="form-group">
      <label>Code de départ (template)</label>
      <textarea name="codeTemplate" rows="5"><%= exercise ? (exercise.codeTemplate || '') : '' %></textarea>
    </div>
    <div class="form-group">
      <label>Sortie attendue</label>
      <textarea name="expectedOutput" rows="2"><%= exercise ? (exercise.expectedOutput || '') : '' %></textarea>
    </div>
  </div>

  <div class="form-group">
    <label>Badge débloqué en cas de réussite (optionnel)</label>
    <input type="text" name="badgeIdOnSuccess" placeholder="ex: fast-learner" value="<%= exercise ? (exercise.badgeIdOnSuccess || '') : '' %>">
  </div>

  <div class="form-checkbox">
    <input type="checkbox" name="unlocksCertificate" id="unlocksCertificate" <%= exercise && exercise.unlocksCertificate ? 'checked' : '' %>>
    <label for="unlocksCertificate">Réussir cet exercice débloque un certificat</label>
  </div>

  <hr>
  <h4><i class="fa-solid fa-list-check"></i> Questions (QCM / Vrai-Faux / Réponse libre)</h4>
  <div id="questions-container"></div>
  <button type="button" class="btn btn-ghost btn-sm" id="add-question-btn"><i class="fa-solid fa-plus"></i> Ajouter une question</button>

  <button type="submit" class="btn btn-primary" style="margin-top:10px;">
    <%= exercise ? 'Enregistrer les modifications' : 'Créer l\'exercice' %>
  </button>
</form>

<template id="question-template">
  <div class="question-block">
    <div class="question-block-header">
      <strong>Question</strong>
      <button type="button" class="btn btn-danger btn-sm remove-question-btn"><i class="fa-solid fa-trash"></i></button>
    </div>
    <div class="form-group">
      <label>Énoncé</label>
      <input type="text" class="q-text" placeholder="Quelle est la capitale du Cameroun ?">
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Type</label>
        <select class="q-type">
          <option value="mcq">QCM</option>
          <option value="true_false">Vrai / Faux</option>
          <option value="text_input">Réponse libre</option>
          <option value="code_output">Sortie de code</option>
        </select>
      </div>
      <div class="form-group">
        <label>Points</label>
        <input type="number" class="q-points" value="1">
      </div>
    </div>
    <div class="form-group">
      <label>Options (une par ligne — pour QCM/Vrai-Faux)</label>
      <textarea class="q-options" rows="3" placeholder="Yaoundé&#10;Douala&#10;Bafoussam"></textarea>
    </div>
    <div class="form-group">
      <label>Réponse correcte (texte exact)</label>
      <input type="text" class="q-correct" placeholder="Yaoundé">
    </div>
    <div class="form-group">
      <label>Explication (affichée après la réponse)</label>
      <input type="text" class="q-explanation">
    </div>
  </div>
</template>

<script>
  const container = document.getElementById('questions-container');
  const tpl = document.getElementById('question-template');
  let qIndex = 0;

  function addQuestionBlock(values) {
    const node = tpl.content.cloneNode(true);
    const block = node.querySelector('.question-block');
    const idx = qIndex++;

    function nameField(cls, field) {
      const el = block.querySelector(cls);
      el.name = `questions[${idx}][${field}]`;
    }
    nameField('.q-text', 'questionText');
    nameField('.q-type', 'type');
    nameField('.q-points', 'points');
    nameField('.q-options', 'options');
    nameField('.q-correct', 'correctAnswer');
    nameField('.q-explanation', 'explanation');

    if (values) {
      block.querySelector('.q-text').value = values.questionText || '';
      block.querySelector('.q-type').value = values.type || 'mcq';
      block.querySelector('.q-points').value = values.points || 1;
      block.querySelector('.q-options').value = (values.options || []).join('\n');
      block.querySelector('.q-correct').value = values.correctAnswer || '';
      block.querySelector('.q-explanation').value = values.explanation || '';
    }

    block.querySelector('.remove-question-btn').addEventListener('click', () => block.remove());
    container.appendChild(block);
  }

  document.getElementById('add-question-btn').addEventListener('click', () => addQuestionBlock());

  // Pré-remplissage si édition
  const existingQuestions = <%- exercise && exercise.questions ? JSON.stringify(exercise.questions) : '[]' %>;
  existingQuestions.forEach((q) => addQuestionBlock(q));

  // Afficher/masquer les champs "code" selon le type d'exercice
  const typeSelect = document.getElementById('exercise-type');
  const codeFields = document.getElementById('code-fields');
  function toggleCodeFields() {
    codeFields.style.display = typeSelect.value === 'code_challenge' ? 'block' : 'none';
  }
  typeSelect.addEventListener('change', toggleCodeFields);
  toggleCodeFields();
</script>
