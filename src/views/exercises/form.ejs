<%
  const exBase = exercise
    ? `/instructor/courses/${courseId}/modules/${moduleId}/exercises/${exercise.id}`
    : `/instructor/courses/${courseId}/modules/${moduleId}/exercises`;
%>

<div class="section-header">
  <div>
    <h2><i class="fa-solid fa-clipboard-question"></i>
      <%= exercise ? "Modifier l'exercice" : 'Nouvel exercice / Quiz' %>
    </h2>
    <p class="text-muted">Module : <%= moduleId %></p>
  </div>
  <a href="/instructor/courses/<%= courseId %>" class="btn btn-ghost btn-sm">
    <i class="fa-solid fa-arrow-left"></i> Retour à la formation
  </a>
</div>

<form action="<%= exBase %>" method="POST" class="form card" style="max-width:820px;" id="exercise-form">

  <div class="form-row">
    <div class="form-group">
      <label>Titre <span class="req">*</span></label>
      <input type="text" name="title" required value="<%= exercise ? exercise.title : '' %>"
        placeholder="ex: Quiz — Les bases de Dart">
    </div>
    <div class="form-group">
      <label>Type</label>
      <select name="type" id="exercise-type">
        <% ['quiz','exam','certification_test','code_challenge'].forEach(function(t) { %>
          <option value="<%= t %>" <%= exercise && exercise.type === t ? 'selected' : '' %>>
            <%= t === 'quiz' ? '📝 Quiz (QCM)' : t === 'exam' ? '📋 Examen noté' : t === 'certification_test' ? '🏆 Test de certification' : '💻 Exercice de code' %>
          </option>
        <% }) %>
      </select>
    </div>
  </div>

  <div class="form-group">
    <label>Description / Consigne</label>
    <textarea name="description" rows="3" class="form-textarea"
      placeholder="Explique ce que l'étudiant doit faire..."><%= exercise ? exercise.description : '' %></textarea>
  </div>

  <div class="form-row">
    <div class="form-group">
      <label>Ordre</label>
      <input type="number" name="order" value="<%= exercise ? exercise.order : 1 %>">
    </div>
    <div class="form-group">
      <label>Seuil de réussite (%)</label>
      <input type="number" name="passingScore" min="0" max="100"
        value="<%= exercise ? exercise.passingScore : 70 %>">
    </div>
    <div class="form-group">
      <label>XP récompensé</label>
      <input type="number" name="xpReward" value="<%= exercise ? exercise.xpReward : 25 %>">
    </div>
    <div class="form-group">
      <label>Durée limite (min)</label>
      <input type="number" name="timeLimitMin"
        value="<%= exercise && exercise.timeLimitMin ? exercise.timeLimitMin : '' %>"
        placeholder="—">
    </div>
  </div>

  <!-- Champs code_challenge -->
  <div id="code-fields" class="card" style="background:#fafbfd;display:none;">
    <h4 style="margin:0 0 16px;font-size:.95rem;"><i class="fa-solid fa-code"></i> Paramètres de l'exercice de code</h4>
    <div class="form-group">
      <label>Langage</label>
      <select name="codeLanguage">
        <% ['dart','python','javascript','kotlin'].forEach(function(lang) { %>
          <option value="<%= lang %>" <%= exercise && exercise.codeLanguage === lang ? 'selected' : '' %>>
            <%= lang.charAt(0).toUpperCase() + lang.slice(1) %>
          </option>
        <% }) %>
      </select>
    </div>
    <div class="form-group">
      <label>Code de départ (template affiché à l'étudiant)</label>
      <textarea name="codeTemplate" rows="6" class="form-textarea"
        style="font-family:monospace;font-size:.82rem;"
        placeholder="void main() {&#10;  // Complète ce code...&#10;}"><%= exercise ? (exercise.codeTemplate || '') : '' %></textarea>
    </div>
    <div class="form-group">
      <label>Sortie attendue</label>
      <textarea name="expectedOutput" rows="2" class="form-textarea"
        style="font-family:monospace;font-size:.82rem;"
        placeholder="Hello, World!"><%= exercise ? (exercise.expectedOutput || '') : '' %></textarea>
    </div>
  </div>

  <!-- Badge et certificat -->
  <div class="form-row">
    <div class="form-group">
      <label>Badge débloqué en cas de réussite</label>
      <input type="text" name="badgeIdOnSuccess"
        placeholder="ID du badge (optionnel)"
        value="<%= exercise ? (exercise.badgeIdOnSuccess || '') : '' %>">
    </div>
    <div class="form-group" style="justify-content:flex-end;padding-top:24px;">
      <div class="form-checkbox">
        <input type="checkbox" name="unlocksCertificate" id="unlocksCertificate"
          <%= exercise && exercise.unlocksCertificate ? 'checked' : '' %>>
        <label for="unlocksCertificate">Débloque un certificat en cas de réussite</label>
      </div>
    </div>
  </div>

  <hr style="border:none;border-top:1.5px solid var(--border);margin:8px 0 20px;">

  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
    <h4 style="font-size:.95rem;margin:0;"><i class="fa-solid fa-list-check"></i> Questions</h4>
    <button type="button" class="btn btn-ghost btn-sm" id="add-question-btn">
      <i class="fa-solid fa-plus"></i> Ajouter une question
    </button>
  </div>
  <div id="questions-container"></div>

  <div class="form-actions">
    <a href="/instructor/courses/<%= courseId %>" class="btn btn-ghost">Annuler</a>
    <button type="submit" class="btn btn-primary">
      <i class="fa-solid fa-<%= exercise ? 'floppy-disk' : 'plus' %>"></i>
      <%= exercise ? 'Enregistrer' : "Créer l'exercice" %>
    </button>
  </div>
</form>

<template id="question-template">
  <div class="question-block card" style="margin-bottom:14px;background:#fafbfd;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
      <strong style="font-size:.88rem;">Question <span class="q-num"></span></strong>
      <button type="button" class="btn-delete remove-question-btn">
        <i class="fa-solid fa-trash"></i>
      </button>
    </div>
    <div class="form-group">
      <label>Énoncé <span class="req">*</span></label>
      <input type="text" class="q-text" placeholder="ex: Quelle est la bonne réponse ?">
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Type de question</label>
        <select class="q-type">
          <option value="mcq">QCM (choix multiple)</option>
          <option value="true_false">Vrai / Faux</option>
          <option value="text_input">Réponse libre</option>
          <option value="code_output">Sortie de code</option>
        </select>
      </div>
      <div class="form-group">
        <label>Points</label>
        <input type="number" class="q-points" value="1" min="1">
      </div>
    </div>
    <div class="form-group">
      <label>Options (une par ligne — pour QCM / Vrai-Faux)</label>
      <textarea class="q-options" rows="3" class="form-textarea"
        placeholder="Option A&#10;Option B&#10;Option C"></textarea>
    </div>
    <div class="form-group">
      <label>Réponse correcte (texte exact) <span class="req">*</span></label>
      <input type="text" class="q-correct" placeholder="ex: Option A">
    </div>
    <div class="form-group">
      <label>Explication (affichée à l'étudiant après la réponse)</label>
      <input type="text" class="q-explanation" placeholder="ex: Car...">
    </div>
  </div>
</template>

<script>
(function() {
  const container = document.getElementById('questions-container');
  const tpl       = document.getElementById('question-template');
  const addBtn    = document.getElementById('add-question-btn');
  const typeSelect = document.getElementById('exercise-type');
  const codeFields = document.getElementById('code-fields');
  let qIndex = 0;

  // Toggle champs code
  function toggleCodeFields() {
    codeFields.style.display = typeSelect.value === 'code_challenge' ? 'block' : 'none';
  }
  typeSelect.addEventListener('change', toggleCodeFields);
  toggleCodeFields();

  // Ajouter une question
  function addQuestion(values) {
    const node  = tpl.content.cloneNode(true);
    const block = node.querySelector('.question-block');
    const idx   = qIndex++;

    block.querySelector('.q-num').textContent = idx + 1;

    const fields = { '.q-text':'questionText', '.q-type':'type', '.q-points':'points',
                     '.q-options':'options', '.q-correct':'correctAnswer', '.q-explanation':'explanation' };
    Object.entries(fields).forEach(([cls, field]) => {
      const el = block.querySelector(cls);
      el.name  = `questions[${idx}][${field}]`;
    });

    if (values) {
      block.querySelector('.q-text').value        = values.questionText  || '';
      block.querySelector('.q-type').value        = values.type          || 'mcq';
      block.querySelector('.q-points').value      = values.points        || 1;
      block.querySelector('.q-options').value     = (values.options || []).join('\n');
      block.querySelector('.q-correct').value     = values.correctAnswer || '';
      block.querySelector('.q-explanation').value = values.explanation   || '';
    }

    block.querySelector('.remove-question-btn').addEventListener('click', () => block.remove());
    container.appendChild(block);
  }

  addBtn.addEventListener('click', () => addQuestion());

  // Pré-remplissage édition
  const existing = <%- exercise && exercise.questions ? JSON.stringify(exercise.questions) : '[]' %>;
  existing.forEach(q => addQuestion(q));
})();
</script>
